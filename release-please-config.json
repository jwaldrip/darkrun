{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "include-component-in-tag": false,
  "draft": false,
  "prerelease": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "toml", "path": "Cargo.toml", "jsonpath": "$.workspace.package.version" },
        { "type": "json", "path": "plugin/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-arm64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-x64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-x64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-arm64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "npm/win32-x64/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "crates/darkrun-api/openapi.json", "jsonpath": "$.info.version" }
      ]
    }
  }
}
